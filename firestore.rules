rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Invite allowlist: anyone can check ONE specific email by exact doc id
    // (no `list` permission granted, so the full list can't be enumerated).
    // Real users only get write access if their token email exists here.
    function isAllowlisted() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/allowlist/$(request.auth.token.email));
    }

    match /allowlist/{email} {
      allow get: if true;
      allow write: if false; // managed manually via Firebase Console / admin tooling only
    }

    // Private per-user data — only the owning, allowlisted user may read/write.
    match /users/{uid} {
      allow read, write: if request.auth != null
        && request.auth.uid == uid
        && isAllowlisted();
    }

    // Shared, cross-user visible subsets. Any allowlisted user can read all of
    // them; a user may only create/update/delete the items they own.
    match /sharedWatchlist/{id} {
      allow read: if isAllowlisted();
      allow create: if isAllowlisted() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isAllowlisted() && resource.data.ownerUid == request.auth.uid;
    }
    match /sharedContacts/{id} {
      allow read: if isAllowlisted();
      allow create: if isAllowlisted() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isAllowlisted() && resource.data.ownerUid == request.auth.uid;
    }
    match /sharedCheckouts/{id} {
      allow read: if isAllowlisted();
      allow create: if isAllowlisted() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isAllowlisted() && resource.data.ownerUid == request.auth.uid;
    }
  }
}
